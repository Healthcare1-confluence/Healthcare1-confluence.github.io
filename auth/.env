# Environment Configuration for Auth Service
# Simple Password Authentication - Any @ascendion.com email allowed

# Server
ENV=development
PORT=8001

# Database
# SQLite is used automatically (app.db will be created)

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# =====================================
# LOGIN CONFIGURATION
# =====================================

# Shared Password - All team members use this with their @ascendion.com email
# Any email with @ascendion.com domain is allowed
SHARED_PASSWORD=Healthcare@doc2025

# =====================================
# CONFLUENCE
# =====================================

CONFLUENCE_DOCS_URL=https://healthcare1-confluence.github.io/

# CORS
ALLOWED_ORIGIN=*
